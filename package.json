{
  "name": "imessage-command-center",
  "version": "1.0.0",
  "description": "Schedule and manage iMessages from your Mac",
  "main": "main.js",
  "scripts": {
    "dev:react":    "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "build":        "vite build",
    "dmg":          "vite build && electron-builder --mac dmg",
    "pack":         "vite build && electron-builder --mac --dir"
  },
  "dependencies": {
    "node-schedule": "^2.1.1"
  },
  "build": {
    "appId": "com.you.imessage-command-center",
    "productName": "iMessage Command Center",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "node_modules/node-schedule/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.0"
  }
}
